{
  "name": "@wdio/nightwatch-devtools",
  "version": "1.4.0",
  "description": "Nightwatch adapter for WebdriverIO DevTools - reuses existing backend, UI, and capture infrastructure",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "show-trace": "./bin/show-trace.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webdriverio/devtools.git",
    "directory": "packages/nightwatch-devtools"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "nightwatch": {
    "plugin": true
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "watch": "tsup src/index.ts --format esm --dts --sourcemap --watch",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "example": "nightwatch -c ../../examples/nightwatch/nightwatch.conf.cjs",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "nightwatch",
    "devtools",
    "debugging",
    "testing"
  ],
  "author": "WebdriverIO Team",
  "license": "MIT",
  "dependencies": {
    "@wdio/devtools-backend": "workspace:*",
    "@wdio/devtools-script": "workspace:*",
    "@wdio/logger": "^9.18.0",
    "@xmldom/xmldom": "^0.9.8",
    "fluent-ffmpeg": "^2.1.3",
    "import-meta-resolve": "^4.2.0",
    "stacktrace-parser": "^0.1.11",
    "webdriverio": "^9.27.2",
    "ws": "^8.21.0",
    "xpath": "^0.0.34",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/ws": "^8.18.1",
    "@wdio/devtools-core": "workspace:^",
    "@wdio/devtools-shared": "workspace:^",
    "chromedriver": "^150.0.1",
    "nightwatch": "^3.16.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "devtools": "^8.42.0",
    "nightwatch": ">=3.0.0"
  }
}
