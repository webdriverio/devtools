{
  "name": "devtools-monorepo",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "demo": "wdio run ./example/wdio.conf.ts",
    "demo:nightwatch": "pnpm --filter @wdio/nightwatch-devtools example",
    "dev": "pnpm --parallel dev",
    "preview": "pnpm --parallel preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:debug": "node --inspect-brk ./node_modules/.bin/vitest run",
    "lint": "pnpm --parallel lint",
    "watch": "pnpm build --watch"
  },
  "pnpm": {
    "overrides": {
      "vite": "^8.0.7",
      "@types/node": "25.6.0",
      "@codemirror/state": "6.5.4"
    },
    "ignoredBuiltDependencies": [
      "chromedriver"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "@typescript-eslint/utils": "^8.40.0",
    "@vitest/browser": "^4.0.16",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^64.0.0",
    "happy-dom": "^20.0.11",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.9",
    "postcss-lit": "^1.2.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.12",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.4",
    "typescript": "^6.0.2",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.7",
    "vitest": "^4.0.16",
    "webdriverio": "^9.19.1"
  },
  "dependencies": {
    "@wdio/cli": "9.27.0"
  }
}
